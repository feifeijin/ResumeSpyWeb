# Local Development Environment
# Copy this file to .env.local for local development overrides
#
# Environment file policy:
# - .env.development — committed; used for PR previews and local dev defaults
# - .env.production  — NOT committed (gitignored); real values live in the
#                      Vercel project's Production environment variables
# - .env.local       — NOT committed; personal local overrides
#
# This .env.example file documents available variables.

# API Base URL - points to backend API
# For local development, use your local backend:
VITE_API_BASE_URL=https://localhost:7227/

# Supabase (public anon key — safe to expose in browser builds)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
