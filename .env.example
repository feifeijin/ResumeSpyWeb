# Local Development Environment
# Copy this file to .env.local for local development overrides
# 
# NOTE: This project includes committed environment files:
# - .env.development (used for PR previews)
# - .env.production (used for production deployments)
#
# This .env.example file is for documenting available variables

# API Base URL - points to backend API
# For local development, use your local backend:
VITE_API_BASE_URL=https://localhost:7227/

# For team members who want to test against DEV API locally:
# VITE_API_BASE_URL=https://api-dev.resumespy.example.com/

# For team members who want to test against PROD API locally (not recommended):
# VITE_API_BASE_URL=https://api.resumespy.example.com/

# ── Analytics ───────────────────────────────────────────────
# Both providers are gated on these env vars — leave empty for local dev
# and they silently no-op (no script tag injected, no PostHog network calls).
# Real values live in Vercel project env vars per environment.

# Plausible (page views + traffic attribution)
# VITE_PLAUSIBLE_DOMAIN=resumespy.feifeijin.com
# VITE_PLAUSIBLE_API_HOST=https://plausible.io

# PostHog (product funnel + retention)
# VITE_POSTHOG_KEY=phc_xxx
# VITE_POSTHOG_HOST=https://us.i.posthog.com
